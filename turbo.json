{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "ui": "tui",
  "tasks": {
    "build": {
      "env": ["DEV", "URL", "BASE_URL"],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!.env.example"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "env": ["PORT", "URL", "BASE_URL"],
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!.env.example"],
      "persistent": true
    },
    "test": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!.env.example"],
      "persistent": true
    },
    "codegen": {
      "outputs": ["src/generated/**/*"],
      "dependsOn": ["^codegen"],
      "cache": false
    },
    "@exiftools/client#lint": {
      "dependsOn": ["@exiftools/client#codegen"]
    }
  }
}
