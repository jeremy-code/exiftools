{
  "name": "@exifi/exif-utils",
  "version": "0.0.0",
  "private": false,
  "exports": {
    ".": {
      "@exifi/development": "./src/index.js",
      "default": "./src/index"
    },
    "./*": {
      "@exifi/development": "./src/*.js",
      "default": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@exifi/eslint-config": "workspace:*",
    "@exifi/tsconfig": "workspace:*",
    "vitest": "^4.1.7"
  }
}
