{
  "name": "@exiftools/exif-utils",
  "version": "0.0.0",
  "private": false,
  "exports": {
    ".": {
      "@exiftools/development": "./src/index.js",
      "default": "./src/index"
    },
    "./*": {
      "@exiftools/development": "./src/*.js",
      "default": "./src/*"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@exiftools/eslint-config": "workspace:*",
    "@exiftools/tsconfig": "workspace:*",
    "vitest": "^4.1.5"
  }
}
